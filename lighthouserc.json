{
    "ci": {
      "collect": {
        "url": [
          "http://localhost:8080/",
          "http://localhost:8080/login"
        ],
        "numberOfRuns": 3
      },
      "assert": {
        "assertions": {
          "categories:performance": ["warn", { "minScore": 0.5 }],
          "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
          "speed-index": ["warn", { "maxNumericValue": 5000 }],
          "interactive": ["warn", { "maxNumericValue": 5000 }]
        }
      }
    }
  }